    <text x="230"  y="340" fill="#fb923c" font-size="8" letter-spacing="1" text-anchor="middle">② SSL SWEEP</text>
    <text x="310"  y="340" fill="#a3e635" font-size="8" letter-spacing="1" text-anchor="middle">③ OB + IMPULSE</text>
    <text x="460"  y="340" fill="#f5c542" font-size="8" letter-spacing="1" text-anchor="middle">④ RETRACEMENT → ENTRY</text>
    <text x="640"  y="340" fill="#22c55e" font-size="8" letter-spacing="1" text-anchor="middle">⑤ EXPANSION TO TARGETS</text>
  </svg>`;
}

function openTopic(key) {
  const t = topics[key];
  const overlay = document.getElementById('modal-overlay');
  const content = document.getElementById('modal-content');

  let sectionsHTML = t.sections.map(s => `
    <div class="section">
      <div class="section-label">${s.label}</div>
      ${s.content}
    </div>
  `).join('');

  let stepsHTML = t.strategy.steps.map(s => `
    <div class="step">
      <div class="step-num">${s.n}</div>
      <div class="step-text"><strong>${s.title}:</strong> ${s.text}</div>
    </div>
  `).join('');

  content.innerHTML = `
    <button class="modal-back" onclick="closeTopic()">← Back to Overview</button>
    <div class="modal-header" style="--accent: ${t.accent}">
      <div class="modal-tag">${t.tag}</div>
      <h2 class="modal-title">${t.title}</h2>
      <p class="modal-subtitle">${t.subtitle}</p>
    </div>

    <div style="--accent: ${t.accent}">
      <div class="chart-container">
        <div class="chart-title">// Visual Diagram</div>
        ${t.chart()}
      </div>

      ${sectionsHTML}

      <div class="strategy-box">
        <h4>${t.strategy.name}</h4>
        <p style="font-size:13px;color:#9ca3af;line-height:1.7;margin-bottom:8px;">${t.strategy.desc}</p>
        <div class="strategy-diagram">
          <div class="strategy-diagram-label">// Strategy Setup — Annotated Chart</div>
          ${t.strategy.chart()}
        </div>
        <div class="strategy-steps">${stepsHTML}</div>
      </div>
    </div>
  `;

  overlay.classList.add('active');
  overlay.scrollTop = 0;
  document.body.style.overflow = 'hidden';
}

function closeTopic() {
  document.getElementById('modal-overlay').classList.remove('active');
  document.body.style.overflow = '';
}

// Close on Escape
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') closeTopic();
});
</script>

