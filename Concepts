<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Smart Money Concepts — Trading Mastery</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=IBM+Plex+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #080b10;
    --surface: #0d1117;
    --border: rgba(255,255,255,0.07);
    --gold: #f5c542;
    --gold-dim: rgba(245,197,66,0.15);
    --teal: #00e5c3;
    --red: #ff4f6a;
    --blue: #4fa3ff;
    --purple: #c084fc;
    --orange: #fb923c;
    --cyan: #22d3ee;
    --lime: #a3e635;
    --text: #e8eaed;
    --muted: #6b7280;
    --card-h: 340px;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'IBM Plex Mono', monospace;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ─── NOISE OVERLAY ─── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 999;
    opacity: 0.4;
  }

  /* ─── HERO / HOME ─── */
  #home {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 60px 24px 80px;
  }

  .hero-label {
    font-size: 11px;
    letter-spacing: 4px;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .hero-label::before, .hero-label::after {
    content: '';
    width: 40px;
    height: 1px;
    background: var(--gold);
    opacity: 0.5;
  }

  .hero-title {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: clamp(38px, 7vw, 86px);
    line-height: 1;
    text-align: center;
    letter-spacing: -2px;
    margin-bottom: 12px;
    background: linear-gradient(135deg, #fff 40%, var(--gold) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-sub {
    font-size: 13px;
    color: var(--muted);
    letter-spacing: 1px;
    text-align: center;
    margin-bottom: 64px;
  }

  /* ─── CHART BG DECORATION ─── */
  .chart-bg {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: 260px;
    pointer-events: none;
    z-index: 0;
    opacity: 0.07;
  }

  /* ─── TILES GRID ─── */
  .tiles {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    width: 100%;
    max-width: 1100px;
    position: relative;
    z-index: 1;
  }

  .tiles .tile:nth-child(4) { grid-column: 1 / 2; }
  .tiles .tile:nth-child(5) { grid-column: 2 / 3; }

  /* center last 2 tiles */
  .tiles-row2 {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    width: 100%;
    max-width: 740px;
    margin-top: 0;
  }

  .tile {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 32px 28px 28px;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    min-height: 220px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .tile::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--accent);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .tile:hover::before { opacity: 1; }

  .tile:hover {
    transform: translateY(-6px);
    border-color: rgba(255,255,255,0.15);
    box-shadow: 0 20px 60px rgba(0,0,0,0.5), 0 0 40px var(--glow);
  }

  .tile[data-topic="support"]   { --accent: var(--teal);   --glow: rgba(0,229,195,0.12); }
  .tile[data-topic="resistance"]{ --accent: var(--red);    --glow: rgba(255,79,106,0.12); }
  .tile[data-topic="trendlines"]{ --accent: var(--blue);   --glow: rgba(79,163,255,0.12); }
  .tile[data-topic="fvg"]       { --accent: var(--purple); --glow: rgba(192,132,252,0.12); }
  .tile[data-topic="liquidity"] { --accent: var(--orange); --glow: rgba(251,146,60,0.12); }
  .tile[data-topic="volume"]    { --accent: var(--cyan);   --glow: rgba(34,211,238,0.12); }
  .tile[data-topic="orderblock"]{ --accent: var(--lime);   --glow: rgba(163,230,53,0.12); }

  .tile-icon {
    font-size: 36px;
    margin-bottom: 16px;
    display: block;
  }

  .tile-num {
    font-size: 10px;
    color: var(--accent);
    letter-spacing: 3px;
    margin-bottom: 8px;
    font-weight: 500;
  }

  .tile-title {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 22px;
    color: #fff;
    margin-bottom: 10px;
  }

  .tile-desc {
    font-size: 12px;
    color: var(--muted);
    line-height: 1.7;
    flex: 1;
  }

  .tile-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    letter-spacing: 2px;
    color: var(--accent);
    margin-top: 20px;
    text-transform: uppercase;
    font-weight: 500;
    transition: gap 0.2s;
  }

  .tile:hover .tile-cta { gap: 10px; }

  /* mini SVG chart on each tile */
  .tile-chart {
    position: absolute;
    bottom: 0; right: 0;
    opacity: 0.12;
    pointer-events: none;
  }

  /* ─── MODAL OVERLAY ─── */
  #modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(4,6,10,0.95);
    z-index: 100;
    overflow-y: auto;
    animation: fadeIn 0.3s ease;
  }

  #modal-overlay.active { display: block; }

  @keyframes fadeIn { from { opacity:0; } to { opacity:1; } }

  .modal-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 40px 24px 80px;
    animation: slideUp 0.4s cubic-bezier(0.16,1,0.3,1);
  }

  @keyframes slideUp {
    from { transform: translateY(40px); opacity:0; }
    to   { transform: translateY(0);    opacity:1; }
  }

  .modal-back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    letter-spacing: 2px;
    color: var(--muted);
    text-transform: uppercase;
    cursor: pointer;
    margin-bottom: 40px;
    transition: color 0.2s;
    background: none;
    border: none;
    font-family: inherit;
    padding: 0;
  }
  .modal-back:hover { color: #fff; }

  .modal-header {
    margin-bottom: 40px;
    border-bottom: 1px solid var(--border);
    padding-bottom: 32px;
  }

  .modal-tag {
    font-size: 10px;
    letter-spacing: 4px;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .modal-title {
    font-family: 'Syne', sans-serif;
    font-size: clamp(32px, 5vw, 56px);
    font-weight: 800;
    color: #fff;
    line-height: 1.1;
    letter-spacing: -1px;
    margin-bottom: 16px;
  }

  .modal-subtitle {
    font-size: 13px;
    color: var(--muted);
    max-width: 600px;
    line-height: 1.8;
  }

  /* ─── CONTENT SECTIONS ─── */
  .section {
    margin-bottom: 48px;
  }

  .section-label {
    font-size: 10px;
    letter-spacing: 4px;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .section h3 {
    font-family: 'Syne', sans-serif;
    font-size: 20px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 14px;
  }

  .section p {
    font-size: 13px;
    line-height: 1.9;
    color: #9ca3af;
    margin-bottom: 14px;
  }

  .section ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .section ul li {
    font-size: 13px;
    color: #9ca3af;
    line-height: 1.7;
    padding-left: 20px;
    position: relative;
  }

  .section ul li::before {
    content: '›';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-size: 16px;
  }

  /* ─── VISUAL CHART SVGs ─── */
  .chart-container {
    background: #0a0e14;
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px;
    margin: 24px 0;
    position: relative;
    overflow: hidden;
  }

  .chart-container::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(255,255,255,0.02) 0%, transparent 70%);
  }

  .chart-title {
    font-size: 11px;
    letter-spacing: 3px;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  /* ─── STRATEGY BOX ─── */
  .strategy-box {
    background: linear-gradient(135deg, rgba(245,197,66,0.05) 0%, rgba(245,197,66,0.02) 100%);
    border: 1px solid rgba(245,197,66,0.2);
    border-left: 3px solid var(--gold);
    border-radius: 0 12px 12px 0;
    padding: 28px 32px;
    margin-top: 32px;
    position: relative;
  }

  .strategy-box::before {
    content: '⚡ STRATEGY';
    position: absolute;
    top: -10px;
    left: 24px;
    background: var(--bg);
    padding: 0 8px;
    font-size: 10px;
    letter-spacing: 4px;
    color: var(--gold);
    font-weight: 500;
  }

  .strategy-box h4 {
    font-family: 'Syne', sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: var(--gold);
    margin-bottom: 16px;
  }

  .strategy-steps {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-top: 16px;
  }

  .step {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .step-num {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--gold-dim);
    border: 1px solid rgba(245,197,66,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    color: var(--gold);
    font-weight: 600;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .step-text {
    font-size: 13px;
    color: #9ca3af;
    line-height: 1.7;
  }

  .step-text strong { color: #e8eaed; }

  /* ─── TAGS ─── */
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 16px;
  }

  .tag {
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 5px 12px;
    border-radius: 4px;
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border);
    color: var(--muted);
  }

  /* ─── 2-COL GRID ─── */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin: 20px 0;
  }

  .info-card {
    background: #0a0e14;
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 20px;
  }

  .info-card h4 {
    font-family: 'Syne', sans-serif;
    font-size: 14px;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 10px;
  }

  .info-card p {
    font-size: 12px;
    margin-bottom: 0;
  }

  /* ─── STRATEGY DIAGRAM ─── */
  .strategy-diagram {
    margin: 28px 0 20px;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid rgba(245,197,66,0.15);
    background: #07090e;
  }

  .strategy-diagram-label {
    font-size: 10px;
    letter-spacing: 3px;
    color: var(--gold);
    text-transform: uppercase;
    padding: 10px 16px 6px;
    opacity: 0.7;
    background: rgba(245,197,66,0.04);
    border-bottom: 1px solid rgba(245,197,66,0.1);
  }

  .strategy-diagram svg {
    display: block;
    width: 100%;
  }

  /* ─── SCROLLBAR ─── */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 2px; }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 768px) {
    .tiles { grid-template-columns: 1fr; }
    .tiles-row2 { grid-template-columns: 1fr; max-width: 100%; }
    .two-col { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>

<!-- ─── HOME PAGE ─── -->
